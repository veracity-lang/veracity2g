diff --git a/benchmarks/invariants/acc.vcy b/benchmarks/invariants/acc.vcy
new file mode 100644
index 0000000..660c0e8
--- /dev/null
+++ b/benchmarks/invariants/acc.vcy
@@ -0,0 +1,13 @@
+/* Accumulator: a running total and a count both stay non-negative.
+   Each iteration adds i to acc and increments both i and count. */
+int main() {
+    int acc   = 0;
+    int count = 0;
+    int i     = 0;
+    while (i < 50) invariant acc >= 0 && count >= 0 && i >= 0 {
+        acc   = acc + i;
+        count = count + 1;
+        i     = i + 1;
+    }
+    return acc;
+}
diff --git a/benchmarks/invariants/bounded.vcy b/benchmarks/invariants/bounded.vcy
new file mode 100644
index 0000000..72c1261
--- /dev/null
+++ b/benchmarks/invariants/bounded.vcy
@@ -0,0 +1,8 @@
+/* Bounded counter: i stays within [0, 100] throughout. */
+int main() {
+    int i = 0;
+    while (i < 100) invariant i >= 0 && i <= 100 {
+        i = i + 1;
+    }
+    return i;
+}
diff --git a/benchmarks/invariants/dec.vcy b/benchmarks/invariants/dec.vcy
new file mode 100644
index 0000000..00f079d
--- /dev/null
+++ b/benchmarks/invariants/dec.vcy
@@ -0,0 +1,8 @@
+/* Descending counter: i remains non-negative as long as the guard holds. */
+int main() {
+    int i = 100;
+    while (i > 0) invariant i >= 0 {
+        i = i - 1;
+    }
+    return i;
+}
diff --git a/benchmarks/invariants/diff.vcy b/benchmarks/invariants/diff.vcy
new file mode 100644
index 0000000..950b9ca
--- /dev/null
+++ b/benchmarks/invariants/diff.vcy
@@ -0,0 +1,11 @@
+/* Difference invariant: the gap (a - b) stays constant throughout.
+   Invariant: a - b == 5 */
+int main() {
+    int a = 15;
+    int b = 10;
+    while (a > 0) invariant a - b == 5 {
+        a = a - 1;
+        b = b - 1;
+    }
+    return a;
+}
diff --git a/benchmarks/invariants/inc.vcy b/benchmarks/invariants/inc.vcy
new file mode 100644
index 0000000..1942920
--- /dev/null
+++ b/benchmarks/invariants/inc.vcy
@@ -0,0 +1,9 @@
+/* Ascending counter: i stays non-negative throughout. */
+int main() {
+    int i = 0;
+    int n = 10;
+    while (i < n) invariant i >= 0 {
+        i = i + 1;
+    }
+    return i;
+}
diff --git a/benchmarks/invariants/nested.vcy b/benchmarks/invariants/nested.vcy
new file mode 100644
index 0000000..f0689ba
--- /dev/null
+++ b/benchmarks/invariants/nested.vcy
@@ -0,0 +1,14 @@
+/* Nested loops: each loop carries its own invariant.
+   Outer invariant: i >= 0.  Inner invariant: j >= 0. */
+int main() {
+    int i = 0;
+    int n = 5;
+    while (i < n) invariant i >= 0 {
+        int j = 0;
+        while (j < i) invariant j >= 0 {
+            j = j + 1;
+        }
+        i = i + 1;
+    }
+    return i;
+}
diff --git a/benchmarks/invariants/product.vcy b/benchmarks/invariants/product.vcy
new file mode 100644
index 0000000..b8ef39e
--- /dev/null
+++ b/benchmarks/invariants/product.vcy
@@ -0,0 +1,11 @@
+/* Doubling loop: product stays positive, index stays non-negative. */
+int main() {
+    int p = 1;
+    int i = 0;
+    int n = 8;
+    while (i < n) invariant p >= 1 && i >= 0 {
+        p = p * 2;
+        i = i + 1;
+    }
+    return p;
+}
diff --git a/benchmarks/invariants/stride.vcy b/benchmarks/invariants/stride.vcy
new file mode 100644
index 0000000..0261e8d
--- /dev/null
+++ b/benchmarks/invariants/stride.vcy
@@ -0,0 +1,9 @@
+/* Stride-2 counter: x stays non-negative and even throughout.
+   Invariant: x >= 0 && x % 2 == 0 */
+int main() {
+    int x = 20;
+    while (x > 0) invariant x >= 0 && x % 2 == 0 {
+        x = x - 2;
+    }
+    return x;
+}
diff --git a/benchmarks/invariants/sum.vcy b/benchmarks/invariants/sum.vcy
new file mode 100644
index 0000000..96df964
--- /dev/null
+++ b/benchmarks/invariants/sum.vcy
@@ -0,0 +1,11 @@
+/* Summation: both the index and the running total stay non-negative. */
+int main() {
+    int i = 0;
+    int s = 0;
+    int n = 20;
+    while (i < n) invariant s >= 0 && i >= 0 {
+        s = s + i;
+        i = i + 1;
+    }
+    return s;
+}
diff --git a/benchmarks/invariants/two-vars.vcy b/benchmarks/invariants/two-vars.vcy
new file mode 100644
index 0000000..824e54d
--- /dev/null
+++ b/benchmarks/invariants/two-vars.vcy
@@ -0,0 +1,10 @@
+/* Two variables: x counts down, y is a fixed lower bound.
+   x >= y is inductive because x decreases while y stays fixed. */
+int main() {
+    int x = 10;
+    int y = 0;
+    while (x > y) invariant x >= y {
+        x = x - 1;
+    }
+    return x;
+}
