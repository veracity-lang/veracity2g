(define-fun states_equal
  ( (err Bool)
    (i Int)
    (a (Array Int Int))
    (len_a Int)
    (n Int)
    (argc Int)
    (argv (Array Int String))
    (realWorld_data (Array String (Array Int String)))
    (realWorld_linenum (Array String Int))
