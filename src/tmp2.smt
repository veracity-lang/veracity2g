(define-fun oper () Bool (and 
  (m1_dummyMethod_1_pre_condition err i a len_a n argc argv realWorld_data realWorld_linenum realWorld_opened)
  (m1_dummyMethod_1_post_condition err i a len_a n argc argv realWorld_data realWorld_linenum realWorld_opened err1 i1 a1 len_a1 n1 argc1 argv1 realWorld_data1 realWorld_linenum1 realWorld_opened1 result_0_1)
  (m1_dummyMethod_1_pre_condition err2 i2 a2 len_a2 n2 argc2 argv2 realWorld_data2 realWorld_linenum2 realWorld_opened2)
  (m1_dummyMethod_1_post_condition err2 i2 a2 len_a2 n2 argc2 argv2 realWorld_data2 realWorld_linenum2 realWorld_opened2 err21 i21 a21 len_a21 n21 argc21 argv21 realWorld_data21 realWorld_linenum21 realWorld_opened21 result_0_21)
  (m2_dummyMethod_2_pre_condition err i a len_a n argc argv realWorld_data realWorld_linenum realWorld_opened)
  (m2_dummyMethod_2_post_condition err i a len_a n argc argv realWorld_data realWorld_linenum realWorld_opened err2 i2 a2 len_a2 n2 argc2 argv2 realWorld_data2 realWorld_linenum2 realWorld_opened2 result_0_2)
  (m2_dummyMethod_2_pre_condition err1 i1 a1 len_a1 n1 argc1 argv1 realWorld_data1 realWorld_linenum1 realWorld_opened1)
  (m2_dummyMethod_2_post_condition err1 i1 a1 len_a1 n1 argc1 argv1 realWorld_data1 realWorld_linenum1 realWorld_opened1 err12 i12 a12 len_a12 n12 argc12 argv12 realWorld_data12 realWorld_linenum12 realWorld_opened12 result_0_12)
  (or (not err12) (not err21))
))

(define-fun bowtie () Bool (and
   (= result_0_1 result_0_21)
   (= result_0_2 result_0_12)
   (postcondition n12 a12 len_a12)
   (states_equal err12 i12 a12 len_a12 n12 argc12 argv12 realWorld_data12 realWorld_linenum12 realWorld_opened12 err21 i21 a21 len_a21 n21 argc21 argv21 realWorld_data21 realWorld_linenum21 realWorld_opened21)
))

(assert (not (=> (and oper (and (and (> n 0) (< n len_a)) true)) bowtie)))
(check-sat)
(get-model)